---
export const prerender = true;

import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { marked } from 'marked';

const raw = readFileSync(resolve('docs/ROADMAP.md'), 'utf-8');
const content = await marked(raw);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Roadmap — Figma → Code Research</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <header class="border-b bg-white px-6 py-4">
      <div class="mx-auto max-w-4xl flex items-center gap-4">
        <a href="/" class="text-sm text-gray-500 hover:text-gray-900">← Experiments</a>
        <span class="text-gray-300">|</span>
        <h1 class="text-lg font-semibold">Roadmap</h1>
      </div>
    </header>

    <main class="mx-auto max-w-4xl px-6 py-10">
      <article class="prose prose-gray max-w-none" set:html={content} />
    </main>
  </body>
</html>
